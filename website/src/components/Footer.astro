---
const currentYear = new Date().getFullYear();

const links = [
  { label: 'Support', href: '#support' },
  { label: 'GitHub', href: 'https://github.com/Atmosphere/atmosphere', external: true },
  { label: 'Contact', href: '/contact/' },
];
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-top">
      <a href="/" class="footer-logo">
        <img src="/logo.svg" alt="Async IO" width="28" height="28" style="border-radius: 4px;" />
        <span>Async IO</span>
      </a>

      <nav class="footer-links">
        {links.map((link) => (
          <a
            href={link.href}
            class="footer-link"
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {link.label}
            {link.external && (
              <svg class="external-icon" width="10" height="10" viewBox="0 0 12 12" fill="none">
                <path d="M3.5 8.5L8.5 3.5M8.5 3.5H4.5M8.5 3.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </a>
        ))}
      </nav>
    </div>

    <div class="footer-divider"></div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; 2008&ndash;{currentYear} <a href="https://async-io.org">Async-IO.org</a>. All rights reserved.
      </p>
      <p class="footer-tagline">
        Real-time infrastructure for the JVM since 2008.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-2xl) var(--space-xl) var(--space-xl);
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-text-primary);
    transition: color 0.2s var(--ease-out-quad);
  }

  .footer-logo:hover {
    color: var(--color-accent);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color 0.2s var(--ease-out-quad);
  }

  .footer-link:hover {
    color: var(--color-text-primary);
  }

  .external-icon {
    opacity: 0.5;
  }

  .footer-link:hover .external-icon {
    opacity: 1;
  }

  .footer-divider {
    height: 1px;
    margin: var(--space-xl) 0;
    background: var(--color-border);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-copyright {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .footer-copyright a {
    color: var(--color-text-secondary);
    transition: color 0.2s var(--ease-out-quad);
  }

  .footer-copyright a:hover {
    color: var(--color-text-primary);
  }

  .footer-tagline {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-style: italic;
    font-family: var(--font-display);
  }

  @media (max-width: 640px) {
    .footer {
      padding: var(--space-xl) var(--space-md);
    }

    .footer-top {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .footer-links {
      gap: var(--space-lg);
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--space-sm);
      text-align: center;
    }
  }
</style>
