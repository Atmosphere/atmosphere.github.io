---
const capabilities = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2a4 4 0 0 0-4 4v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z"/>
      <circle cx="12" cy="15" r="2"/>
    </svg>`,
    title: '@Agent Annotation',
    description: 'One class, one annotation. Endpoints, commands, tools, skill files, conversation memory, and protocol exposure are all auto-wired.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
      <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
      <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
    </svg>`,
    title: '@Coordinator Orchestration',
    description: 'Manage fleets of agents with parallel fan-out, sequential pipelines, conditional routing, and result evaluation.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 8v4l3 3"/>
    </svg>`,
    title: 'Durable Workflows',
    description: 'CheckpointStore persists workflow state as parent-chained snapshots. Pause workflows without holding a thread; resume via REST.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    </svg>`,
    title: 'Human-in-the-Loop',
    description: '@RequiresApproval pauses tool execution for human approval. The virtual thread parks cheaply until the client responds.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>`,
    title: '5 Channels',
    description: 'Slack, Telegram, Discord, WhatsApp, Messenger &mdash; alongside the default browser endpoint. Set a bot token and the same @Command + AI pipeline works on every channel.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <path d="M3 9h18M9 21V9"/>
    </svg>`,
    title: 'Admin Control Plane',
    description: 'Real-time dashboard, REST API for governance, runtimes, agents, A2A tasks, and flow graphs, WebSocket event stream, and MCP tools for managing agents.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
    </svg>`,
    title: 'Observability',
    description: 'OpenTelemetry tracing, Micrometer metrics, and AI token usage tracking. Auto-configured with Spring Boot.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="16 18 22 12 16 6"/>
      <polyline points="8 6 2 12 8 18"/>
    </svg>`,
    title: 'Client SDKs',
    description: 'atmosphere.js with React, Vue, Svelte, and React Native hooks. Streaming, offline queues, auth token refresh.',
  },
];
---

<section class="capabilities" id="capabilities">
  <div class="capabilities-container">
    <div class="section-header">
      <span class="section-label">What We Deliver</span>
      <h2 class="section-title">Production-grade agent infrastructure</h2>
      <p class="section-description">
        Everything you need to build, deploy, and operate AI agents in production.
        Spring Boot 4.0 and Quarkus 3.21+ auto-configuration included.
      </p>
    </div>

    <div class="capabilities-grid">
      {capabilities.map((cap, index) => (
        <article class="capability-card" style={`--delay: ${(index * 0.06).toFixed(2)}s`}>
          <div class="capability-icon" set:html={cap.icon} />
          <h3 class="capability-title">{cap.title}</h3>
          <p class="capability-description">{cap.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .capabilities {
    padding: var(--space-4xl) var(--space-xl);
    background: var(--color-bg-secondary);
    position: relative;
  }

  .capabilities::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-accent), transparent);
  }

  .capabilities-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-3xl);
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .section-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .capability-card {
    padding: var(--space-xl);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: all 0.3s var(--ease-out-quad);
    animation: fadeInUp 0.6s var(--ease-out-expo) var(--delay) both;
  }

  .capability-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-3px);
    box-shadow: 0 16px 32px -16px rgba(0, 0, 0, 0.4);
  }

  .capability-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-accent-glow);
    border-radius: 8px;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    transition: all 0.3s var(--ease-out-quad);
  }

  .capability-card:hover .capability-icon {
    background: var(--color-accent);
    color: var(--color-bg-primary);
  }

  .capability-title {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .capability-description {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1024px) {
    .capabilities-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .capabilities {
      padding: var(--space-3xl) var(--space-md);
    }

    .capabilities-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
