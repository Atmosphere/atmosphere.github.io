---
const steps = [
  {
    n: '01',
    title: 'Install the CLI',
    code: 'brew install Atmosphere/tap/atmosphere',
    note: 'Also: SDKMAN, npx, or direct JAR download',
  },
  {
    n: '02',
    title: 'Create a project',
    code: 'atmosphere create my-agent --template ai-chat',
    note: '11 templates: ai-chat, ai-tools, rag-chat, mcp-server, coordinator…',
  },
  {
    n: '03',
    title: 'Run it',
    code: 'cd my-agent && atmosphere run',
    note: 'Opens http://localhost:8080 with a live streaming chat console',
  },
];
---

<section class="get-started" id="get-started">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Get Started</span>
      <h2 class="section-title">Running in five minutes</h2>
      <p class="section-description">
        Zero config, zero boilerplate. Install the CLI, scaffold a project, set one environment
        variable, and you have a streaming <code>@Agent</code> on WebSocket, SSE, and long-polling.
      </p>
    </div>

    <div class="steps">
      {steps.map((step) => (
        <div class="step">
          <div class="step-header">
            <span class="step-number">{step.n}</span>
            <h3 class="step-title">{step.title}</h3>
          </div>
          <pre class="step-code"><code>{step.code}</code></pre>
          <p class="step-note">{step.note}</p>
        </div>
      ))}
    </div>

    <div class="example">
      <div class="example-header">
        <span class="example-label">My<span class="example-accent">Agent.java</span></span>
      </div>
      <pre class="example-code"><code><span class="kw">@Agent</span>(name = <span class="str">"my-agent"</span>, skillFile = <span class="str">"skill.md"</span>)
<span class="kw">public class</span> <span class="cls">MyAgent</span> &#123;

    <span class="kw">@Prompt</span>
    <span class="kw">public void</span> onPrompt(<span class="cls">String</span> message, <span class="cls">StreamingSession</span> session) &#123;
        session.stream(message);  <span class="cmt">// Works on Spring AI, LC4j, ADK, Embabel, Koog, SK, or Built-in</span>
    &#125;

    <span class="kw">@AiTool</span>(description = <span class="str">"Look up order status"</span>)
    <span class="kw">public</span> <span class="cls">OrderStatus</span> lookupOrder(<span class="cls">String</span> orderId) &#123;
        <span class="kw">return</span> orderService.findById(orderId);
    &#125;
&#125;</code></pre>
    </div>

    <div class="cta-row">
      <a href="https://async-io.org/docs/tutorial/00-cli/" class="btn btn-primary">
        CLI Quick Start
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="https://async-io.org/docs/tutorial/02-getting-started/" class="btn btn-secondary">
        First App Tutorial
      </a>
      <a href="https://github.com/Atmosphere/atmosphere/tree/main/samples" class="btn btn-tertiary">
        Browse 24 samples &rarr;
      </a>
    </div>
  </div>
</section>

<style>
  .get-started {
    padding: var(--space-4xl) var(--space-xl);
    position: relative;
  }

  .get-started::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-accent), transparent);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto var(--space-3xl);
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .section-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .section-description code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-3xl);
  }

  .step {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-xl);
    transition: all 0.3s var(--ease-out-quad);
  }

  .step:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-2px);
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .step-number {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 0.2em 0.6em;
    border-radius: 4px;
    border: 1px solid rgba(0, 212, 255, 0.25);
  }

  .step-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0;
  }

  .step-code {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-primary);
    background: var(--color-bg-primary);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    margin: 0 0 var(--space-sm) 0;
    overflow-x: auto;
    white-space: pre;
  }

  .step-code code {
    background: none;
    padding: 0;
    color: inherit;
  }

  .step-note {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  .example {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: var(--space-2xl);
    box-shadow: 0 24px 48px -24px rgba(0, 0, 0, 0.5);
  }

  .example-header {
    padding: var(--space-md) var(--space-xl);
    background: var(--color-bg-tertiary);
    border-bottom: 1px solid var(--color-border);
  }

  .example-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .example-accent {
    color: var(--color-accent);
  }

  .example-code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-text-primary);
    padding: var(--space-xl);
    margin: 0;
    overflow-x: auto;
  }

  .example-code .kw { color: #c792ea; }
  .example-code .cls { color: #ffcb6b; }
  .example-code .str { color: #c3e88d; }
  .example-code .cmt { color: #546e7a; font-style: italic; }

  .cta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s var(--ease-out-quad);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--color-text-primary);
    color: var(--color-bg-primary);
  }

  .btn-primary:hover {
    background: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px var(--color-accent-glow);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-accent);
  }

  .btn-secondary:hover {
    border-color: var(--color-text-muted);
    background: var(--color-bg-elevated);
  }

  .btn-tertiary {
    background: transparent;
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--color-border-accent);
  }

  .btn-tertiary:hover {
    color: var(--color-text-primary);
    text-decoration-color: var(--color-text-muted);
  }

  @media (max-width: 1024px) {
    .steps {
      grid-template-columns: 1fr;
      max-width: 560px;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 640px) {
    .get-started {
      padding: var(--space-3xl) var(--space-md);
    }

    .cta-row {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      justify-content: center;
    }
  }
</style>
