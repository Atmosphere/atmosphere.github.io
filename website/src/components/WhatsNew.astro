---
const highlights = [
  {
    badge: 'New runtime',
    title: 'Microsoft Semantic Kernel',
    description: 'Seventh @AgentRuntime — ChatCompletionService bridge with streaming, system prompts, and TokenUsage reporting. Tool calling deferred to the next release.',
    link: 'https://async-io.org/docs/integrations/semantic-kernel/',
    linkLabel: 'SK integration docs',
  },
  {
    badge: 'New SPI',
    title: 'EmbeddingRuntime',
    description: 'Five implementations — Spring AI (200), LC4j (190), Semantic Kernel (180), Embabel (170), Built-in (50) — resolved by priority. One API, every embedding provider.',
    link: 'https://async-io.org/docs/agents/embeddings/',
    linkLabel: 'EmbeddingRuntime SPI',
  },
  {
    badge: 'New SPI',
    title: 'AgentLifecycleListener',
    description: 'Observability seam with onStart / onToolCall / onToolResult / onCompletion / onError. Error-isolated so a failing listener never breaks the tool-call loop.',
    link: 'https://async-io.org/docs/reference/lifecycle-listener/',
    linkLabel: 'Lifecycle SPI',
  },
  {
    badge: 'New SPI',
    title: 'ExecutionHandle',
    description: 'Cooperative cancel for in-flight @Agent executions. Each runtime wraps its native primitive — HTTP close, coroutine Job cancel, Reactor dispose.',
    link: 'https://async-io.org/docs/reference/execution-handle/',
    linkLabel: 'ExecutionHandle',
  },
  {
    badge: 'Security',
    title: 'ToolApprovalPolicy',
    description: 'Sealed interface: AllowAll / DenyAll / Annotated / Custom. DenyAll short-circuits the ApprovalStrategy so auto-approve can\'t bypass deny mode — fail closed by default.',
    link: 'https://async-io.org/docs/reference/tool-approval-policy/',
    linkLabel: 'ToolApprovalPolicy',
  },
  {
    badge: 'Feature',
    title: 'Prompt caching (CacheHint)',
    description: 'Pipeline-level ResponseCache keyed on SHA-256 of model, system prompt, message, history, tools, and parts. Session-independent so identical prompts hit the same cache line.',
    link: 'https://async-io.org/docs/reference/ai/#prompt-caching',
    linkLabel: 'Prompt caching reference',
  },
  {
    badge: 'Feature',
    title: 'Multi-modal Content',
    description: 'Sealed Content type — Text / Image / Audio / File. Base64-framed wire protocol with explicit mimeType. Runtimes without multi-modal input declare it in capabilities().',
    link: 'https://async-io.org/docs/tutorial/09-ai-endpoint/#multi-modal-input',
    linkLabel: '@AiEndpoint multi-modal',
  },
  {
    badge: 'Feature',
    title: 'Durable HITL workflows',
    description: 'CheckpointStore SPI with in-memory, SQLite, and Redis backends. An approval that arrives after a JVM restart resumes the exact turn on a fresh virtual thread.',
    link: 'https://async-io.org/docs/tutorial/24-durable-hitl/',
    linkLabel: 'Durable HITL tutorial',
  },
  {
    badge: 'Feature',
    title: '@AiEndpoint annotation surface',
    description: 'Declarative promptCache() and retry() on @AiEndpoint — same annotation works on Spring Boot and Quarkus. Quarkus wires via build-time annotation processor.',
    link: 'https://async-io.org/docs/integrations/spring-boot/#aiendpoint-annotation-surfaces',
    linkLabel: '@AiEndpoint surfaces',
  },
];
---

<section class="whats-new" id="whats-new">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Release 4.0.36</span>
      <h2 class="section-title">What shipped in the last wave</h2>
      <p class="section-description">
        Wave 1-6 of the unified <code>@Agent</code> API close-out. Seven runtimes. Full HITL story.
        EmbeddingRuntime SPI. Multi-modal. Prompt caching. Durable workflows that survive JVM restarts.
      </p>
    </div>

    <div class="highlights-grid">
      {highlights.map((h, idx) => (
        <article class="highlight-card" style={`--delay: ${(idx * 0.05).toFixed(2)}s`}>
          <span class={`highlight-badge badge-${h.badge.toLowerCase().replace(/\s+/g, '-')}`}>{h.badge}</span>
          <h3 class="highlight-title">{h.title}</h3>
          <p class="highlight-description">{h.description}</p>
          <a href={h.link} class="highlight-link" target="_blank" rel="noopener noreferrer">
            {h.linkLabel}
            <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
              <path d="M4 12L12 4M12 4H6M12 4v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </article>
      ))}
    </div>

    <div class="release-cta">
      <a href="https://async-io.org/docs/whats-new/" class="btn btn-primary">
        Full release notes
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="https://github.com/Atmosphere/atmosphere/blob/main/CHANGELOG.md" class="btn btn-secondary">
        CHANGELOG.md
      </a>
    </div>
  </div>
</section>

<style>
  .whats-new {
    padding: var(--space-4xl) var(--space-xl);
    position: relative;
  }

  .whats-new::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-accent), transparent);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto var(--space-3xl);
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 0.3em 0.8em;
    border-radius: 4px;
    border: 1px solid rgba(0, 212, 255, 0.2);
    margin-bottom: var(--space-md);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .section-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .section-description code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .highlight-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    transition: all 0.3s var(--ease-out-quad);
    animation: fadeInUp 0.6s var(--ease-out-expo) var(--delay) both;
  }

  .highlight-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-2px);
  }

  .highlight-badge {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25em 0.7em;
    border-radius: 4px;
    margin-bottom: var(--space-md);
    border: 1px solid transparent;
  }

  .badge-new-runtime {
    color: var(--color-accent);
    background: var(--color-accent-glow);
    border-color: rgba(0, 212, 255, 0.25);
  }

  .badge-new-spi {
    color: #c792ea;
    background: rgba(199, 146, 234, 0.08);
    border-color: rgba(199, 146, 234, 0.2);
  }

  .badge-security {
    color: #ff6b9d;
    background: rgba(255, 107, 157, 0.08);
    border-color: rgba(255, 107, 157, 0.2);
  }

  .badge-feature {
    color: #c3e88d;
    background: rgba(195, 232, 141, 0.08);
    border-color: rgba(195, 232, 141, 0.2);
  }

  .highlight-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-sm) 0;
    letter-spacing: -0.01em;
  }

  .highlight-description {
    flex-grow: 1;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-md) 0;
  }

  .highlight-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    text-decoration: none;
    align-self: flex-start;
  }

  .highlight-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .release-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s var(--ease-out-quad);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--color-text-primary);
    color: var(--color-bg-primary);
  }

  .btn-primary:hover {
    background: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px var(--color-accent-glow);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-accent);
  }

  .btn-secondary:hover {
    border-color: var(--color-text-muted);
    background: var(--color-bg-elevated);
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1024px) {
    .highlights-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .whats-new {
      padding: var(--space-3xl) var(--space-md);
    }

    .highlights-grid {
      grid-template-columns: 1fr;
    }

    .release-cta {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
