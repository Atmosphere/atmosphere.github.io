---
// Severity levels referenced by the tier grid. The response times below are
// contractual promises — they are defined here so a buyer can tell what they
// are actually paying for instead of guessing at "S1".
const severities = [
  {
    key: 'S1',
    label: 'Production down',
    text: `A production system is unusable — agents not responding, transport
           dead, data at risk. Response means an engineer who can act, not an
           autoresponder.`,
  },
  {
    key: 'S2',
    label: 'Production degraded',
    text: `Production is running but impaired — a transport falling back, a
           runtime failing intermittently, elevated errors under load. A
           workaround may exist.`,
  },
];

// An "incident" is one reported problem, worked until resolved or until a
// workaround is agreed — not one email and not one hour of engineering.
//
// PRICING: `from` is null for every tier until Async-IO publishes figures. A
// null renders "Pricing on request". Never invent a number here: a plausible
// anchor that turns out to be wrong is worse than no anchor at all.
// 2026 ladder. Response times are FIRST-RESPONSE commitments, never
// resolution — a promise a focused team can keep. See the owner-facing pricing
// note in the vault for how each figure is anchored to a published comparable
// (Red Hat JBoss EAP, Grafana Enterprise, Temporal, Confluent).
const plans = [
  {
    name: 'Developer',
    from: '$2,000',
    period: '/ org / year',
    bestFor: 'Dev, staging and evaluation. Get the team unblocked without a production promise.',
    coverage: 'Business Hours',
    responseS1: 'Next business day',
    responseS2: '2 Business Days',
    incidents: '5 / year',
    phone: false,
    email: true,
    patches: false,
  },
  {
    name: 'Production',
    from: '$9,000',
    period: '/ org / year',
    bestFor: 'Atmosphere on the critical path. A four-hour answer during your working day.',
    coverage: 'Business Hours',
    responseS1: '4 Business Hours',
    responseS2: '1 Business Day',
    incidents: 'Unlimited',
    phone: true,
    email: true,
    patches: true,
    highlight: true,
  },
  {
    name: 'Mission-Critical',
    from: 'from $25,000',
    period: '/ org / year · quoted',
    bestFor: 'Revenue depends on it around the clock. 24×7 cover on a named contact.',
    coverage: '24×7 (S1 / S2)',
    responseS1: '1 Hour · 24×7',
    responseS2: '4 Hours · 24×7',
    incidents: 'Unlimited',
    phone: true,
    email: true,
    patches: true,
  },
];
---

<section class="support" id="support">
  <div class="support-container">
    <div class="section-header">
      <span class="section-label">Enterprise Support</span>
      <h2 class="section-title">Backed by the team that built it</h2>
      <p class="section-description">
        Get direct access to the core engineering team. We wrote the framework,
        we maintain it, and we stand behind it. Meet your production schedule
        and compliance requirements with guaranteed response times.
      </p>
    </div>

    <ul class="coverage-grid">
      <li class="coverage-item">
        <span class="coverage-label">Compliance, audited</span>
        <p class="coverage-text">
          OWASP Agentic Top 10, EU AI Act, HIPAA, and SOC 2 evidence
          matrices ship in-tree and are CI-pinned. Your auditors get a
          build artifact, not a slide deck.
        </p>
      </li>
      <li class="coverage-item">
        <span class="coverage-label">Plan-and-verify</span>
        <p class="coverage-text">
          <code>atmosphere-verifier</code> refuses unsafe LLM-emitted
          workflows before any tool fires &mdash; Meijer
          <em>Guardians of the Agents</em> (CACM, Jan 2026).
        </p>
      </li>
      <li class="coverage-item">
        <a class="coverage-label coverage-label-link" href="https://github.com/microsoft/agent-governance-toolkit" target="_blank" rel="noopener noreferrer">MS Agent Governance Toolkit ↗</a>
        <p class="coverage-text">
          Microsoft's YAML rule schema parsed verbatim, same
          <code>audit_entry</code> JSON shape, same <code>agt verify</code>
          semantics &mdash; drop-in for shops standardising on MS Agent OS.
        </p>
      </li>
      <li class="coverage-item">
        <span class="coverage-label">A2A v1.0.0</span>
        <p class="coverage-text">
          Atmosphere ships the released spec. Pre-1.0 method names are
          aliased server-side so your existing A2A clients keep working
          through the migration.
        </p>
      </li>
      <li class="coverage-item">
        <span class="coverage-label">One contract, twelve runtimes</span>
        <p class="coverage-text">
          <code>policyDenyBlocksRuntimeExecute</code> is a build-time
          invariant for every adapter &mdash; you can't add a runtime
          without proving it honours your governance chain.
        </p>
      </li>
    </ul>

    <div class="severity-defs">
      {severities.map((s) => (
        <div class="severity-item">
          <span class="severity-key">{s.key}</span>
          <div>
            <span class="severity-label">{s.label}</span>
            <p class="severity-text">{s.text}</p>
          </div>
        </div>
      ))}
      <p class="severity-note">
        An <strong>incident</strong> is one reported problem, worked until it is
        resolved or until we agree a workaround &mdash; not one email, and not one
        hour of engineering.
      </p>
    </div>

    <div class="plans-grid">
      {plans.map((plan) => (
        <div class={`plan-card ${plan.highlight ? 'plan-highlight' : ''}`}>
          <h3 class="plan-name">{plan.name}</h3>

          <p class="plan-price">
            {plan.from ?? 'Pricing on request'}
            {plan.from && plan.period && <span class="plan-period">{plan.period}</span>}
          </p>
          <p class="plan-best-for">{plan.bestFor}</p>

          <ul class="plan-features">
            <li>
              <span class="feature-label">Coverage</span>
              <span class="feature-value">{plan.coverage}</span>
            </li>
            <li>
              <span class="feature-label">Response (S1)</span>
              <span class="feature-value">{plan.responseS1}</span>
            </li>
            <li>
              <span class="feature-label">Response (S2)</span>
              <span class="feature-value">{plan.responseS2}</span>
            </li>
            <li>
              <span class="feature-label">Incidents</span>
              <span class="feature-value">{plan.incidents}</span>
            </li>
            <li>
              <span class="feature-label">Phone Support</span>
              <span class={`feature-value ${plan.phone ? 'yes' : 'no'}`}>
                {plan.phone ? '✓' : '—'}
              </span>
            </li>
            <li>
              <span class="feature-label">Email Support</span>
              <span class={`feature-value ${plan.email ? 'yes' : 'no'}`}>
                {plan.email ? '✓' : '—'}
              </span>
            </li>
            <li>
              <span class="feature-label">Emergency Patches</span>
              <span class={`feature-value ${plan.patches ? 'yes' : 'no'}`}>
                {plan.patches ? '✓' : '—'}
              </span>
            </li>
          </ul>

          <a
            href={`/contact/?plan=${encodeURIComponent(plan.name)}`}
            class={`plan-cta ${plan.highlight ? 'plan-cta-highlight' : ''}`}
          >
            {plan.from && plan.from.startsWith('$') ? 'Get Started' : 'Get a Quote'}
          </a>
        </div>
      ))}
    </div>

    <div class="legacy-card">
      <div class="legacy-content">
        <div class="legacy-header">
          <span class="legacy-badge">Legacy</span>
          <h3 class="legacy-title">Atmosphere 2.x / 3.x Support</h3>
        </div>
        <p class="legacy-description">
          Still running Atmosphere 2.x or 3.x in production? We provide long-term support,
          security patches, and migration guidance for legacy deployments. Includes a
          migration path to Atmosphere 4.x when you are ready.
        </p>
      </div>
      <a
        href="/contact/?plan=Legacy"
        class="legacy-cta"
      >
        Talk to Us
      </a>
    </div>

    <div class="support-footer">
      <p>
        Need professional services on a per-hour basis?
        <a href="/contact/?plan=Services">Talk to us</a> for a custom quote.
      </p>
    </div>
  </div>
</section>

<style>
  .support {
    padding: var(--space-4xl) var(--space-xl);
    position: relative;
  }

  .support::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-accent), transparent);
  }

  .support-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-3xl);
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .section-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .coverage-grid {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-3xl);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-lg);
  }

  .coverage-item {
    padding: var(--space-lg);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    transition: border-color 0.2s var(--ease-out-quad);
  }

  .coverage-item:hover {
    border-color: var(--color-border-accent);
  }

  .coverage-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  a.coverage-label-link {
    text-decoration: none;
    transition: color 0.2s var(--ease-out-quad);
  }

  a.coverage-label-link:hover {
    color: var(--color-text-primary);
  }

  .coverage-text {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .coverage-text code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    padding: 0.1em 0.35em;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-accent);
  }

  .plans-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .plan-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    transition: all 0.3s var(--ease-out-quad);
  }

  .plan-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-4px);
  }

  .plan-highlight {
    border-color: var(--color-accent);
    background: var(--color-accent-glow);
  }

  .plan-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: var(--space-xs);
    text-align: center;
  }

  .plan-price {
    font-family: var(--font-mono);
    font-size: 1.375rem;
    color: var(--color-text-primary);
    text-align: center;
    margin-bottom: var(--space-sm);
  }

  .plan-period {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .plan-best-for {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    text-align: center;
    margin-bottom: var(--space-lg);
    min-height: 2.4em;
  }

  .severity-defs {
    max-width: 900px;
    margin: 0 auto var(--space-3xl);
    padding: var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg-tertiary);
  }

  .severity-item {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .severity-key {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    border: 1px solid var(--color-border-accent);
    border-radius: 6px;
    padding: 2px 8px;
    height: fit-content;
  }

  .severity-label {
    display: block;
    font-weight: 600;
    font-size: 0.9375rem;
    margin-bottom: 2px;
    color: var(--color-text-primary);
  }

  .severity-text {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .severity-note {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .severity-note strong {
    color: var(--color-text-secondary);
  }

  .plan-features {
    list-style: none;
    flex-grow: 1;
    margin-bottom: var(--space-lg);
  }

  .plan-features li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.8125rem;
  }

  .plan-features li:last-child {
    border-bottom: none;
  }

  .feature-label {
    color: var(--color-text-muted);
  }

  .feature-value {
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .feature-value.yes {
    color: var(--color-accent);
  }

  .feature-value.no {
    color: var(--color-text-muted);
  }

  .plan-cta {
    display: block;
    text-align: center;
    padding: var(--space-md);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border-accent);
    border-radius: 8px;
    color: var(--color-text-primary);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s var(--ease-out-quad);
  }

  .plan-cta:hover {
    background: var(--color-bg-elevated);
    border-color: var(--color-text-muted);
  }

  .plan-cta-highlight {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-bg-primary);
  }

  .plan-cta-highlight:hover {
    background: var(--color-accent-dim);
    border-color: var(--color-accent-dim);
  }

  .legacy-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
    padding: var(--space-xl) var(--space-2xl);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: all 0.3s var(--ease-out-quad);
  }

  .legacy-card:hover {
    border-color: var(--color-border-accent);
  }

  .legacy-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .legacy-badge {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    background: var(--color-bg-tertiary);
    padding: 0.2em 0.6em;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .legacy-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
  }

  .legacy-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 640px;
  }

  .legacy-cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    padding: var(--space-md) var(--space-xl);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border-accent);
    border-radius: 8px;
    color: var(--color-text-primary);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s var(--ease-out-quad);
    white-space: nowrap;
  }

  .legacy-cta:hover {
    background: var(--color-bg-elevated);
    border-color: var(--color-text-muted);
  }

  .support-footer {
    text-align: center;
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .support-footer p {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
  }

  .support-footer a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .support-footer a:hover {
    text-decoration: underline;
  }

  @media (max-width: 1024px) {
    .plans-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .support {
      padding: var(--space-3xl) var(--space-md);
    }

    .plans-grid {
      grid-template-columns: 1fr;
    }

    .legacy-card {
      flex-direction: column;
      align-items: flex-start;
      padding: var(--space-xl);
    }

    .legacy-cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
