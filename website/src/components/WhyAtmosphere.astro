---
const rows = [
  {
    feature: 'Unified runtime abstraction',
    atmosphere: { value: '7 backends', tone: 'yes' },
    langchain: { value: 'Python/JS only', tone: 'partial' },
    litellm: { value: '100+ LLM APIs', tone: 'yes', note: 'provider abstraction, not runtime' },
    vercel: { value: '20+ providers', tone: 'yes', note: 'TypeScript only' },
  },
  {
    feature: 'JVM-native',
    atmosphere: { value: 'JDK 21+ virtual threads', tone: 'yes' },
    langchain: { value: 'LangChain4j (subset)', tone: 'partial' },
    litellm: { value: 'Python proxy', tone: 'no' },
    vercel: { value: 'TypeScript', tone: 'no' },
  },
  {
    feature: 'Real-time streaming transport',
    atmosphere: { value: 'WebSocket + SSE + WebTransport/HTTP3 + gRPC + long-poll, auto-fallback', tone: 'yes' },
    langchain: { value: 'HTTP/SSE', tone: 'partial' },
    litellm: { value: 'HTTP/SSE', tone: 'partial' },
    vercel: { value: 'SSE + Edge streaming', tone: 'partial' },
  },
  {
    feature: 'Multi-agent orchestration',
    atmosphere: { value: '@Coordinator + @Fleet + A2A protocol', tone: 'yes' },
    langchain: { value: 'LangGraph (separate library)', tone: 'partial' },
    litellm: { value: 'Not in scope', tone: 'no' },
    vercel: { value: 'Not in scope', tone: 'no' },
  },
  {
    feature: 'Human-in-the-loop approval',
    atmosphere: { value: 'First-class @RequiresApproval + wire protocol + sealed ToolApprovalPolicy', tone: 'yes' },
    langchain: { value: 'Interrupt pattern in LangGraph', tone: 'partial' },
    litellm: { value: 'Not in scope', tone: 'no' },
    vercel: { value: 'DIY', tone: 'no' },
  },
  {
    feature: 'Durable workflows',
    atmosphere: { value: 'CheckpointStore SPI — SQLite, Redis, pluggable', tone: 'yes' },
    langchain: { value: 'LangGraph checkpoints', tone: 'partial' },
    litellm: { value: 'Not in scope', tone: 'no' },
    vercel: { value: 'Not in scope', tone: 'no' },
  },
  {
    feature: 'Agent protocols auto-wired',
    atmosphere: { value: 'MCP + A2A + AG-UI from classpath', tone: 'yes' },
    langchain: { value: 'MCP manual', tone: 'partial' },
    litellm: { value: 'Not in scope', tone: 'no' },
    vercel: { value: 'Not in scope', tone: 'no' },
  },
  {
    feature: 'Rooms & presence',
    atmosphere: { value: '@RoomService + LlmRoomMember + Redis/Kafka clustering', tone: 'yes' },
    langchain: { value: 'Not in scope', tone: 'no' },
    litellm: { value: 'Not in scope', tone: 'no' },
    vercel: { value: 'Not in scope', tone: 'no' },
  },
  {
    feature: 'Deployment model',
    atmosphere: { value: 'Library — Spring Boot / Quarkus / WAR / native image', tone: 'yes' },
    langchain: { value: 'Library', tone: 'yes' },
    litellm: { value: 'Proxy service', tone: 'partial' },
    vercel: { value: 'Next.js edge functions', tone: 'partial' },
  },
];
---

<section class="why" id="why">
  <div class="why-container">
    <div class="section-header">
      <span class="section-label">Why Atmosphere</span>
      <h2 class="section-title">One framework. Seven runtimes. Zero vendor lock-in.</h2>
      <p class="section-description">
        Multi-framework AI chaos is the 2026 version of the 2008 WebSocket/SSE/long-polling chaos.
        Atmosphere solved the transport problem in 2008 and is solving the AI runtime problem in 2026.
      </p>
    </div>

    <div class="table-wrapper">
      <table class="comparison">
        <thead>
          <tr>
            <th class="feature-col">&nbsp;</th>
            <th class="atmosphere-col">
              <span class="col-brand">Atmosphere</span>
              <span class="col-meta">JVM · unified runtime abstraction</span>
            </th>
            <th>
              <span class="col-brand">LangChain</span>
              <span class="col-meta">Python / JS / Java subset</span>
            </th>
            <th>
              <span class="col-brand">LiteLLM</span>
              <span class="col-meta">Python proxy</span>
            </th>
            <th>
              <span class="col-brand">Vercel AI SDK</span>
              <span class="col-meta">TypeScript</span>
            </th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <th class="feature-col" scope="row">{row.feature}</th>
              <td class={`cell cell-${row.atmosphere.tone}`}>
                <span class="cell-value">{row.atmosphere.value}</span>
                {row.atmosphere.note && <span class="cell-note">{row.atmosphere.note}</span>}
              </td>
              <td class={`cell cell-${row.langchain.tone}`}>
                <span class="cell-value">{row.langchain.value}</span>
                {row.langchain.note && <span class="cell-note">{row.langchain.note}</span>}
              </td>
              <td class={`cell cell-${row.litellm.tone}`}>
                <span class="cell-value">{row.litellm.value}</span>
                {row.litellm.note && <span class="cell-note">{row.litellm.note}</span>}
              </td>
              <td class={`cell cell-${row.vercel.tone}`}>
                <span class="cell-value">{row.vercel.value}</span>
                {row.vercel.note && <span class="cell-note">{row.vercel.note}</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="disclaimer">
      Every tool in this comparison is excellent at what it does — LangChain ships the
      richest ecosystem of integrations, LiteLLM is the canonical OpenAI-compatible proxy,
      and Vercel AI SDK is unmatched for Next.js apps. Atmosphere is the option when your
      production surface is <strong>JVM + real-time + multi-runtime</strong>.
    </p>
  </div>
</section>

<style>
  .why {
    padding: var(--space-4xl) var(--space-xl);
    background: var(--color-bg-secondary);
    position: relative;
  }

  .why::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-accent), transparent);
  }

  .why-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto var(--space-3xl);
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .section-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .table-wrapper {
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow-x: auto;
    margin-bottom: var(--space-xl);
  }

  .comparison {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    min-width: 900px;
  }

  .comparison th,
  .comparison td {
    padding: var(--space-md) var(--space-lg);
    text-align: left;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .comparison thead th {
    background: var(--color-bg-secondary);
    font-weight: 500;
    border-bottom: 1px solid var(--color-border-accent);
  }

  .comparison tbody tr:last-child th,
  .comparison tbody tr:last-child td {
    border-bottom: none;
  }

  .comparison tbody tr:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .feature-col {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-primary);
    width: 200px;
  }

  .atmosphere-col {
    background: var(--color-accent-glow) !important;
  }

  .col-brand {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-primary);
    margin-bottom: 0.15em;
  }

  .col-meta {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .cell {
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .cell-value {
    display: block;
    color: var(--color-text-primary);
  }

  .cell-note {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.2em;
    font-style: italic;
  }

  .cell-yes .cell-value {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .cell-yes .cell-value::before {
    content: '✓ ';
    color: var(--color-accent);
    font-weight: 600;
  }

  .cell-partial .cell-value {
    color: var(--color-text-secondary);
  }

  .cell-partial .cell-value::before {
    content: '◐ ';
    color: #d4b060;
    font-weight: 600;
  }

  .cell-no .cell-value {
    color: var(--color-text-muted);
  }

  .cell-no .cell-value::before {
    content: '— ';
    color: var(--color-text-muted);
  }

  .disclaimer {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .disclaimer strong {
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .why {
      padding: var(--space-3xl) var(--space-md);
    }
  }
</style>
