---
const pillars = [
  {
    label: 'Transports',
    title: '5 transports, one API',
    description: 'Your application code declares what it does. Atmosphere handles how it is delivered &mdash; and falls back automatically when a transport is unavailable.',
    items: [
      { name: 'WebSocket', detail: 'Full-duplex communication over a single TCP connection. The standard for real-time web applications since 2011.', url: 'https://datatracker.ietf.org/doc/html/rfc6455', urlLabel: 'RFC 6455' },
      { name: 'SSE', detail: 'Server-Sent Events. A simple HTTP-based protocol for server-to-client streaming with automatic reconnection built into the browser.', url: 'https://html.spec.whatwg.org/multipage/server-sent-events.html', urlLabel: 'WHATWG Spec' },
      { name: 'WebTransport/HTTP3', detail: 'Multiplexed, low-latency transport over QUIC with native WebTransport support &mdash; auto-detected via AsyncSupport with zero-config Jetty 12 QUIC or Reactor Netty sidecar.', url: 'https://w3c.github.io/webtransport/', urlLabel: 'W3C Spec' },
      { name: 'Long-Polling', detail: 'HTTP long-polling with automatic reconnection. Works everywhere, even behind the most restrictive corporate firewalls and proxies.', url: 'https://datatracker.ietf.org/doc/html/rfc6202', urlLabel: 'RFC 6202' },
      { name: 'gRPC', detail: 'High-performance RPC framework with bidirectional streaming over HTTP/2. Atmosphere exposes your agents as gRPC services alongside HTTP transports.', url: 'https://grpc.io', urlLabel: 'grpc.io' },
    ],
    extras: ['Auto-fallback', 'Reconnection with jitter', 'Heartbeats', 'Message caching'],
  },
  {
    label: 'Agent Protocols',
    title: '3 protocols, zero configuration',
    description: 'Add the dependency to your classpath and your agent speaks the protocol. No manual endpoint wiring, no boilerplate.',
    items: [
      { name: 'MCP', detail: 'Model Context Protocol. An open standard by Anthropic for connecting AI assistants to tools, resources, and data sources. Expose your @AiTool methods to Claude, Copilot, Cursor, and any MCP-compatible client.', url: 'https://modelcontextprotocol.io', urlLabel: 'modelcontextprotocol.io' },
      { name: 'A2A', detail: 'Agent-to-Agent protocol, originally launched by Google and now stewarded by the Linux Foundation. Enables agents to discover each other via Agent Cards and communicate through JSON-RPC. Your @Agent is automatically discoverable by any A2A-compliant agent.', url: 'https://a2a-protocol.org/', urlLabel: 'A2A Spec' },
      { name: 'AG-UI', detail: 'Agent-User Interaction protocol. Streams agent state (text deltas, tool calls, state transitions) to frontends in real time. Compatible with CopilotKit and other AG-UI clients.', url: 'https://docs.ag-ui.com', urlLabel: 'AG-UI Docs' },
    ],
    extras: ['Auto-registered from classpath', 'Multi-channel: Slack, Telegram, Discord, WhatsApp, Messenger'],
  },
  {
    label: 'AI Runtimes',
    title: '9 backends, swap by dependency',
    description: 'Atmosphere is the infrastructure layer underneath your LLM library. Your @Agent and @AiTool annotations work across every backend; capability flags are pinned by AbstractAgentRuntimeContractTest so adapter rows cannot drift from the running code.',
    items: [
      { name: 'Built-in', detail: 'Atmosphere\'s zero-dependency OpenAI-compatible client. Function calling (up to 5 rounds), JSON mode, vision, audio, prompt caching, native retry. Works against OpenAI, Gemini, Ollama, or any OpenAI-compatible endpoint.', url: 'https://github.com/Atmosphere/atmosphere', urlLabel: 'GitHub' },
      { name: 'Spring AI', detail: 'Spring\'s official AI framework. ChatClient, RAG, VectorStore, auto-configuration. Atmosphere bridges @AiTool to Spring AI\'s function calling system.', url: 'https://spring.io/projects/spring-ai', urlLabel: 'spring.io' },
      { name: 'LangChain4j', detail: 'Java port of the LangChain ecosystem. Chains, AI services, streaming chat models, tool bridging. Atmosphere auto-detects LangChain4j on the classpath and registers tools.', url: 'https://docs.langchain4j.dev', urlLabel: 'langchain4j.dev' },
      { name: 'Google ADK', detail: 'Google\'s Agent Development Kit. Multi-agent orchestration, sessions, the Runner execution engine. Atmosphere is the transport and protocol layer for ADK agents.', url: 'https://google.github.io/adk-docs/', urlLabel: 'Google ADK Docs' },
      { name: 'JetBrains Koog', detail: 'Kotlin-native AI framework by JetBrains. Structured concurrency, typed tools, multi-agent orchestration, Bedrock cache control.', url: 'https://github.com/JetBrains/koog', urlLabel: 'GitHub' },
      { name: 'Semantic Kernel', detail: 'Microsoft\'s enterprise-grade AI orchestration SDK. ChatCompletionService, kernel plugins, memory, planners. Tool calling, structured output, token usage.', url: 'https://learn.microsoft.com/en-us/semantic-kernel/', urlLabel: 'Microsoft Docs' },
      { name: 'Alibaba AgentScope', detail: 'Alibaba\'s multi-agent framework. Structured output, conversation memory, token usage; agents are first-class with explicit tool dispatch managed by your code.', url: 'https://github.com/agentscope-ai/agentscope-java', urlLabel: 'GitHub' },
      { name: 'Embabel', detail: 'Goal-driven agent framework by Rod Johnson, the creator of Spring. Declarative goals, planned execution, native PromptRunner; agent orchestration, tool calling, vision.', url: 'https://embabel.com', urlLabel: 'embabel.com' },
      { name: 'Spring AI Alibaba', detail: 'Spring AI Alibaba ReactAgent. Structured output, conversation memory, prompt-driven tool selection through Spring AI\'s ChatClient surface.', url: 'https://java2ai.com', urlLabel: 'java2ai.com' },
    ],
    extras: ['Portable @AiTool across all backends', 'Capability matrix CI-pinned', 'No code change to swap runtime'],
  },
];
---

<section class="pillars" id="atmosphere">
  <div class="pillars-container">
    <div class="section-header">
      <span class="section-label">The Platform</span>
      <h2 class="section-title">Transports. Protocols. Runtimes.</h2>
      <p class="section-description">
        Build once with <code>@Agent</code> &mdash; deliver over any transport and any protocol.
        Three distinct layers, each independently extensible.
      </p>
    </div>

    <div class="pillars-grid">
      {pillars.map((pillar, pIdx) => (
        <div class="pillar-card" style={`--delay: ${(pIdx * 0.12).toFixed(2)}s`}>
          <div class="pillar-header">
            <span class="pillar-label">{pillar.label}</span>
            <h3 class="pillar-title">{pillar.title}</h3>
            <p class="pillar-description" set:html={pillar.description} />
          </div>

          <ul class="pillar-items">
            {pillar.items.map((item, iIdx) => (
              <li class="pillar-item" data-pillar={pIdx} data-item={iIdx} role="button" tabindex="0">
                <span class="item-name">
                  {item.name}
                  <svg class="item-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span class="item-detail">{item.detail.split('.')[0]}.</span>
              </li>
            ))}
          </ul>

          <div class="pillar-extras">
            {pillar.extras.map((extra) => (
              <span class="extra-tag">{extra}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Modal -->
  <div class="modal-overlay" id="pillarModal" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true">
      <button class="modal-close" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4l10 10M14 4L4 14"/></svg>
      </button>
      <div class="modal-hero">
        <div class="modal-hero-glow"></div>
        <div class="modal-hero-text">
          <span class="modal-label" id="pillarModalLabel"></span>
          <h3 class="modal-title" id="pillarModalTitle"></h3>
        </div>
      </div>
      <div class="modal-divider"></div>
      <div class="modal-body" id="pillarModalBody"></div>
      <div class="modal-footer" id="pillarModalFooter"></div>
    </div>
  </div>
</section>

<script define:vars={{ pillars }}>
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('pillarModal');
    const modalLabel = document.getElementById('pillarModalLabel');
    const modalTitle = document.getElementById('pillarModalTitle');
    const modalBody = document.getElementById('pillarModalBody');
    const modalFooter = document.getElementById('pillarModalFooter');
    const closeBtn = overlay.querySelector('.modal-close');

    function openModal(pIdx, iIdx) {
      const pillar = pillars[pIdx];
      const item = pillar.items[iIdx];
      modalLabel.textContent = pillar.label;
      modalTitle.textContent = item.name;
      modalBody.innerHTML = `<p>${item.detail}</p>`;
      modalFooter.innerHTML = `<a href="${item.url}" class="modal-link" target="_blank" rel="noopener noreferrer">
        ${item.urlLabel}
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M4 12L12 4M12 4H6M12 4v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>`;
      overlay.setAttribute('aria-hidden', 'false');
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    }

    function closeModal() {
      overlay.classList.remove('active');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.pillar-item[data-pillar]').forEach(item => {
      const handler = () => openModal(Number(item.dataset.pillar), Number(item.dataset.item));
      item.addEventListener('click', handler);
      item.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handler(); }
      });
    });

    closeBtn.addEventListener('click', closeModal);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  });
</script>

<style>
  .pillars {
    padding: var(--space-4xl) var(--space-xl);
    position: relative;
  }

  .pillars::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-accent), transparent);
  }

  .pillars-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--space-3xl);
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .section-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .section-description code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .pillar-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: var(--space-xl);
    transition: all 0.3s var(--ease-out-quad);
    animation: fadeInUp 0.6s var(--ease-out-expo) var(--delay) both;
  }

  .pillar-card:hover {
    border-color: var(--color-border-accent);
  }

  .pillar-header {
    margin-bottom: var(--space-xl);
  }

  .pillar-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 0.25em 0.75em;
    border-radius: 4px;
    border: 1px solid rgba(212, 176, 96, 0.2);
    margin-bottom: var(--space-md);
  }

  .pillar-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-sm);
  }

  .pillar-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .pillar-items {
    list-style: none;
    flex-grow: 1;
    margin-bottom: var(--space-lg);
  }

  .pillar-item {
    display: flex;
    flex-direction: column;
    padding: var(--space-sm) var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    cursor: pointer;
    border-radius: 6px;
    transition: all 0.2s var(--ease-out-quad);
  }

  .pillar-item:last-child {
    border-bottom: none;
  }

  .pillar-item:hover {
    background: var(--color-bg-tertiary);
    border-color: transparent;
  }

  .pillar-item:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }

  .item-name {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-primary);
    margin-bottom: 0.15em;
  }

  .item-arrow {
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.2s var(--ease-out-quad);
  }

  .pillar-item:hover .item-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .item-detail {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .pillar-extras {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .extra-tag {
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    background: var(--color-bg-tertiary);
    padding: 0.2em 0.6em;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  /* ── Modal ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0);
    pointer-events: none;
    transition: background 0.4s ease, backdrop-filter 0.4s ease;
  }

  .modal-overlay.active {
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(12px);
    pointer-events: auto;
  }

  .modal {
    position: relative;
    width: min(560px, 100%);
    max-height: calc(100vh - var(--space-3xl));
    overflow-y: auto;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    box-shadow: 0 0 0 1px rgba(212, 176, 96, 0.08), 0 24px 64px -16px rgba(0, 0, 0, 0.7);
    transform: translateY(32px) scale(0.95);
    opacity: 0;
    transition: transform 0.4s var(--ease-out-expo), opacity 0.35s ease;
  }

  .modal-overlay.active .modal {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .modal::-webkit-scrollbar { width: 6px; }
  .modal::-webkit-scrollbar-track { background: transparent; }
  .modal::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }

  .modal-close {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    z-index: 2;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .modal-close:hover {
    color: var(--color-text-primary);
    border-color: var(--color-accent-dim);
    background: rgba(212, 176, 96, 0.08);
  }

  .modal-hero {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-2xl) var(--space-2xl) var(--space-xl);
    overflow: hidden;
  }

  .modal-hero-glow {
    position: absolute;
    top: -60px;
    left: -40px;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(212, 176, 96, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .modal-hero-text {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-right: var(--space-3xl);
  }

  .modal-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    opacity: 0.8;
  }

  .modal-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .modal-divider {
    height: 1px;
    margin: 0 var(--space-2xl);
    background: linear-gradient(90deg, var(--color-accent-dim), var(--color-border) 40%, transparent);
    opacity: 0.5;
  }

  .modal-body {
    padding: var(--space-xl) var(--space-2xl) var(--space-md);
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .modal-body :global(p) {
    margin: 0;
  }

  .modal-footer {
    padding: 0 var(--space-2xl) var(--space-2xl);
  }

  .modal-footer :global(.modal-link) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-accent-glow);
    border: 1px solid rgba(212, 176, 96, 0.25);
    border-radius: 6px;
    transition: all 0.2s var(--ease-out-quad);
    text-decoration: none;
  }

  .modal-footer :global(.modal-link:hover) {
    background: var(--color-accent);
    color: var(--color-bg-primary);
    border-color: var(--color-accent);
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1024px) {
    .pillars-grid {
      grid-template-columns: 1fr;
      max-width: 560px;
      margin: 0 auto;
    }
  }

  @media (max-width: 640px) {
    .pillars {
      padding: var(--space-3xl) var(--space-md);
    }

    .modal-overlay { padding: var(--space-sm); }
    .modal { border-radius: 16px; }
    .modal-hero { padding: var(--space-xl) var(--space-lg) var(--space-lg); }
    .modal-hero-text { padding-right: 0; }
    .modal-divider { margin: 0 var(--space-lg); }
    .modal-body { padding: var(--space-lg) var(--space-lg) var(--space-sm); }
    .modal-footer { padding: 0 var(--space-lg) var(--space-lg); }
  }
</style>
