---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const calendlyUrl = 'https://calendly.com/jfarcand-async-io/30min';

// Tier names the Support section can hand over via ?plan=. This is an
// allowlist, not a hint: the value arrives from the URL and is echoed into the
// page, so anything not on this list is ignored rather than rendered.
const planNames = ['Developer', 'Production', 'Mission-Critical', 'Legacy', 'Services'];
---

<Layout title="Contact — Async IO">
  <Header />
  <main>
    <section class="contact">
      <div class="contact-container">
        <div class="contact-header">
          <span class="section-label">Get in touch</span>
          <h1 class="contact-title">Let's talk</h1>
          <p class="contact-description">
            Book a call with the Async-IO team to discuss enterprise support,
            migration planning, or how Atmosphere fits your architecture.
            You talk to the engineers who wrote the framework.
          </p>
          <p class="plan-context" id="planContext" hidden>
            About the <strong id="planName"></strong> plan.
          </p>
        </div>

        <div class="calendly-embed">
          <div
            class="calendly-inline-widget"
            data-url={calendlyUrl}
            data-base-url={calendlyUrl}
            id="calendlyWidget"
            style="min-width:320px;height:700px;"
          ></div>
        </div>

        <div class="contact-alt">
          <p>
            Prefer email? Reach us at
            <a href="mailto:support@async-io.org" id="emailFallback">support@async-io.org</a>
            &mdash; we answer every message ourselves.
          </p>
          <noscript>
            <p class="contact-noscript">
              The scheduler needs JavaScript. Email
              <a href="mailto:support@async-io.org">support@async-io.org</a>
              and we will send you times.
            </p>
          </noscript>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>

<script is:inline define:vars={{ planNames }}>
  // Carry the tier the buyer clicked in Support across to this page: name it
  // back to them, tag the booking, and preload the email fallback's subject.
  // The value comes from the URL, so it is matched against the allowlist and
  // never interpolated as markup.
  (function () {
    const params = new URLSearchParams(window.location.search);
    const requested = params.get('plan');
    const plan = planNames.find((p) => p.toLowerCase() === (requested || '').toLowerCase());
    if (!plan) return;

    const context = document.getElementById('planContext');
    const name = document.getElementById('planName');
    if (context && name) {
      name.textContent = plan;
      context.hidden = false;
    }

    // utm_content rides through to the Calendly booking so an inbound call is
    // already attributed to a tier before it starts.
    const widget = document.getElementById('calendlyWidget');
    if (widget) {
      const base = widget.getAttribute('data-base-url');
      widget.setAttribute('data-url', base + '?utm_content=' + encodeURIComponent(plan));
    }

    const email = document.getElementById('emailFallback');
    if (email) {
      email.setAttribute(
        'href',
        'mailto:support@async-io.org?subject=' +
          encodeURIComponent(plan + ' plan — Atmosphere support enquiry')
      );
    }
  })();
</script>

<script is:inline>
  // The scheduler is a third-party script on a domain corporate blockers eat.
  // If it has not painted an iframe shortly after load, say so in the page
  // instead of leaving an empty bordered box as the only purchase path.
  window.addEventListener('load', function () {
    window.setTimeout(function () {
      const widget = document.getElementById('calendlyWidget');
      if (!widget || widget.querySelector('iframe')) return;
      const fallback = document.createElement('p');
      fallback.className = 'contact-noscript';
      fallback.innerHTML =
        'The scheduler could not load &mdash; it is likely blocked here. Email ' +
        '<a href="mailto:support@async-io.org">support@async-io.org</a> and we will send you times.';
      widget.replaceChildren(fallback);
    }, 4000);
  });
</script>

<style>
  .contact {
    padding: calc(var(--space-4xl) + 60px) var(--space-xl) var(--space-4xl);
    min-height: 100vh;
  }

  .contact-container {
    max-width: 720px;
    margin: 0 auto;
  }

  .contact-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .contact-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-lg);
  }

  .contact-description {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto;
  }

  .calendly-embed {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: var(--space-2xl);
  }

  .contact-alt {
    text-align: center;
  }

  .contact-alt p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .plan-context {
    margin-top: var(--space-md);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-accent);
  }

  .contact-noscript {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    padding: var(--space-xl);
    text-align: center;
  }

  .contact-alt a {
    color: var(--color-accent);
    transition: color 0.2s var(--ease-out-quad);
  }

  .contact-alt a:hover {
    color: var(--color-text-primary);
  }

  @media (max-width: 640px) {
    .contact {
      padding: calc(var(--space-3xl) + 60px) var(--space-md) var(--space-3xl);
    }
  }
</style>
